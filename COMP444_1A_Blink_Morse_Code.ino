//Morse Code

void setup() {

  pinMode(13, OUTPUT);
}

void loop() {
  //H
  digitalWrite(13, HIGH);
  delay(500);

  digitalWrite(13, LOW);
  delay(500);

  digitalWrite(13, HIGH);
  delay(500);

  digitalWrite(13, LOW);
  delay(500);

  digitalWrite(13, HIGH);
  delay(500);

  digitalWrite(13, LOW);
  delay(500);

  digitalWrite(13, HIGH);
  delay(500);

  digitalWrite(13, LOW);
  delay(1500);

  //E
  digitalWrite(13, HIGH);
  delay(500);

  digitalWrite(13, LOW);
  delay(1500);

  //L
  digitalWrite(13, HIGH);
  delay(500);

  digitalWrite(13, LOW);
  delay(500);

  digitalWrite(13, HIGH);
  delay(1500);

  digitalWrite(13, LOW);
  delay(500);

  digitalWrite(13, HIGH);
  delay(500);

  digitalWrite(13, LOW);
  delay(500);

  digitalWrite(13, HIGH);
  delay(500);

  digitalWrite(13, LOW);
  delay(1500);

  //L
  digitalWrite(13, HIGH);
  delay(500);

  digitalWrite(13, LOW);
  delay(500);

  digitalWrite(13, HIGH);
  delay(1500);

  digitalWrite(13, LOW);
  delay(500);

  digitalWrite(13, HIGH);
  delay(500);

  digitalWrite(13, LOW);
  delay(500);

  digitalWrite(13, HIGH);
  delay(500);

  digitalWrite(13, LOW);
  delay(1500);

  //O
  digitalWrite(13, HIGH);
  delay(1500);

  digitalWrite(13, LOW);
  delay(500);

  digitalWrite(13, HIGH);
  delay(1500);

  digitalWrite(13, LOW);
  delay(500);

  digitalWrite(13, HIGH);
  delay(1500);

  digitalWrite(13, LOW);
  delay(3500);

  //W
  digitalWrite(13, HIGH);
  delay(500);

  digitalWrite(13, LOW);
  delay(500);

  digitalWrite(13, HIGH);
  delay(1500);

  digitalWrite(13, LOW);
  delay(500);
  
  digitalWrite(13, HIGH);
  delay(1500);

  digitalWrite(13, LOW);
  delay(1500);

  //O
  digitalWrite(13, HIGH);
  delay(1500);

  digitalWrite(13, LOW);
  delay(500);

  digitalWrite(13, HIGH);
  delay(1500);

  digitalWrite(13, LOW);
  delay(500);

  digitalWrite(13, HIGH);
  delay(1500);

  digitalWrite(13, LOW);
  delay(3500);

  //R
  digitalWrite(13, HIGH);
  delay(500);

  digitalWrite(13, LOW);
  delay(500);

  digitalWrite(13, HIGH);
  delay(1500);

  digitalWrite(13, LOW);
  delay(500);
  
  digitalWrite(13, HIGH);
  delay(500);

  digitalWrite(13, LOW);
  delay(1500);

  //L
  digitalWrite(13, HIGH);
  delay(500);

  digitalWrite(13, LOW);
  delay(500);

  digitalWrite(13, HIGH);
  delay(1500);

  digitalWrite(13, LOW);
  delay(500);

  digitalWrite(13, HIGH);
  delay(500);

  digitalWrite(13, LOW);
  delay(500);

  digitalWrite(13, HIGH);
  delay(500);

  digitalWrite(13, LOW);
  delay(1500);

  //D
  digitalWrite(13, HIGH);
  delay(1500);

  digitalWrite(13, LOW);
  delay(500);

  digitalWrite(13, HIGH);
  delay(500);

  digitalWrite(13, LOW);
  delay(500);

  digitalWrite(13, HIGH);
  delay(500);

  digitalWrite(13, LOW);
  delay(3500);
}
